# Twitch OAuth / API credentials
# Get these from https://dev.twitch.tv/console

TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_OAUTH_TOKEN=oauth:your_oauth_token_here
TWITCH_REFRESH_TOKEN=your_refresh_token_here

# Your channel & bot username
TWITCH_BOT_USERNAME=your_bot_username
TWITCH_CHANNEL=your_channel_name
TWITCH_BROADCASTER_ID=your_broadcaster_numeric_id

# Discord webhook (optional — for stream alerts, raid alerts, clip alerts, highlight candidates)
DISCORD_WEBHOOK_URL=

# Auto-clip settings
CLIP_COOLDOWN_SECONDS=30
CLIP_TRIGGER_KEYWORDS=clip,CLIP,!clip,POGGERS
AUTO_CLIP_ON_RAID=true
AUTO_CLIP_ON_HYPE_TRAIN=true

# Automation settings
WELCOME_NEW_CHATTERS=true        # Greet first-time chatters per session
AUTO_SO_ON_RAID=true             # Auto shoutout raider in chat
SCHEDULED_MSG_INTERVAL=1200      # Seconds between periodic chat messages (1200 = 20 min)

# Web dashboard (http://localhost:8080)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Twitter/X auto-posting (get keys at https://developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
AUTO_TWEET_LIVE=true
AUTO_TWEET_CLIPS=true

# Auto-raid out when stream ends
AUTO_RAID_OUT=true
RAID_TARGETS=friend1,friend2   # comma-separated Twitch usernames to raid first

# OpenAI (for !ask AI command)
OPENAI_API_KEY=sk-...your_openai_key_here
AI_MODEL=gpt-4o-mini
AI_COOLDOWN_SECONDS=10
